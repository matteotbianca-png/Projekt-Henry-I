# Telegram UI satellite (tools/telegram_ui.py)
TELEGRAM_BOT_TOKEN=
AUTHORIZED_USER_ID=

# Microservice URLs (local REST)
HENRY_CORE_API_URL=http://127.0.0.1:8000
HENRY_API_HOST=127.0.0.1
HENRY_API_PORT=8000
HENRY_WORKER_API_URL=http://127.0.0.1:8001
HENRY_WORKER_API_PORT=8001
HENRY_UI_API_URL=http://127.0.0.1:8002
HENRY_UI_API_HOST=127.0.0.1
HENRY_UI_API_PORT=8002

# LLM
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
# HENRY_CLASSIFY_MODEL=qwen2.5:7b  # override model for document classification

# File pipeline — root folder for inbox + archive
HENRY_FILES_ROOT=/path/to/Henry Files

# Web search (optional)
TAVILY_API_KEY=

# OCR — auto-detected on PATH; override if needed
# TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Encrypted dual memory — paths on mounted HenryData volume
MEMORY_MOUNT_PATH=/Volumes/HenryData
ARCHIVE_DB_PATH=/Volumes/HenryData/archive
PERSONAL_MEMORY_PATH=/Volumes/HenryData/personal_memory.db

# Optional: Ollama embedding model for Chroma archive (default nomic-embed-text)
# HENRY_EMBED_MODEL=nomic-embed-text
